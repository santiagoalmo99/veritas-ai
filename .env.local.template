# VeritasAI — Environment Variables Template
# Copy this file to .env.local and fill in your keys
# All LLM providers have FREE tiers — see veritasai_maestro.md §5.2

# ── LLM Router (Priority 1 → 4) ──────────────────────────
# Groq: 500K tokens/day free → https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras: 1M tokens/day free → https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Google AI Studio: Gemini 2.0 Flash, 1500 req/day free → https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# OpenRouter: 50+ free models rotating → https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Supabase (when ready) ─────────────────────────────────
# https://supabase.com/dashboard → project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional integrations ─────────────────────────────────
# NewsAPI (100 req/day free) → https://newsapi.org/
NEWS_API_KEY=

# Brave Search (2000 req/month free) → https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=

# ── App config ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
